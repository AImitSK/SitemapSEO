# SitemapSEO - Template fuer lokale Entwicklung
# Kopiere diese Datei nach .env.local und befuelle die Werte.

# ── Datenbank (Neon) ───────────────────────────────────────
# `vercel env pull` befuellt diese automatisch.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ── Google Gemini (Vercel AI SDK) ──────────────────────────
# https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Verschluesselung der WordPress-Application-Passwords ──
# 32 Byte, base64. AES-256-GCM. Generieren mit: openssl rand -base64 32
ENCRYPTION_KEY=

# ── Auth (Phase 1) ─────────────────────────────────────────
# Bcrypt-Hash erstellen mit:
#   node -e "console.log(require('bcrypt').hashSync('PASSWORT', 12))"
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
